# Required — server will not start without this
PALAUTH_AUTH_PEPPER=change-me-to-a-random-32-byte-string

# Database
PALAUTH_DATABASE_URL=postgres://palauth:palauth_dev@localhost:5432/palauth?sslmode=disable

# Redis
PALAUTH_REDIS_URL=redis://localhost:6379

# Server
PALAUTH_SERVER_PORT=3000
PALAUTH_SERVER_HOST=0.0.0.0

# Auth
PALAUTH_AUTH_PASSWORD_MIN_LENGTH=15
PALAUTH_AUTH_PASSWORD_MAX_LENGTH=64
PALAUTH_AUTH_ACCESS_TOKEN_TTL=1800
PALAUTH_AUTH_LOCKOUT_THRESHOLD=10
PALAUTH_AUTH_LOCKOUT_DURATION=1800
PALAUTH_AUTH_MFA_LOCKOUT_THRESHOLD=5
PALAUTH_AUTH_INACTIVE_DAYS=90

# Email provider: console | smtp | ses | sendgrid
PALAUTH_EMAIL_PROVIDER=console

# Logging: debug | info | warn | error
PALAUTH_LOG_LEVEL=info
PALAUTH_LOG_FORMAT=json

# FIPS 140-3 mode
PALAUTH_FIPS=false
