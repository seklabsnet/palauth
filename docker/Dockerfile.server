FROM golang:1.26-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /palauth ./cmd/server

FROM alpine:3.21

RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /palauth /usr/local/bin/palauth

EXPOSE 3000
ENTRYPOINT ["palauth"]
